---
interface GiftItem {
  label: string;
  url?: string;
  description?: string;
}

interface Props {
  items: GiftItem[];
  colors: { primary: string; secondary: string; accent: string; background: string; text: string };
  fonts: { heading: string; body: string };
  altBackground?: boolean;
  variant?: string;
}

const { items = [], colors, fonts, altBackground = false, variant = 'classic' } = Astro.props;
const bgColor = altBackground ? colors.secondary : colors.background;
---

{items.length > 0 && (
  <section class="py-20 px-6 text-center" style={`background-color: ${bgColor}`}>
    <div class="max-w-sm mx-auto">
      {variant === 'classic' && (
        <div class="mb-4 flex justify-center opacity-25">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke={colors.primary} stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
        </div>
      )}

      <h2
        class="text-4xl mb-10"
        style={`font-family: '${fonts.heading}', cursive; color: ${colors.primary}`}
      >
        Mesa de Regalos
      </h2>

      <div class="space-y-6">
        {items.map((item) => (
          <div class="rounded-xl p-4" style={`background-color: ${colors.background}; border: 1px solid ${colors.accent}20`}>
            <p class="text-sm font-semibold mb-1" style={`color: ${colors.text}; font-family: '${fonts.body}', sans-serif`}>
              {item.label}
            </p>
            {item.description && (
              <p class="text-xs mb-2" style={`color: ${colors.text}; opacity: 0.5; font-family: '${fonts.body}', sans-serif`}>
                {item.description}
              </p>
            )}
            {item.url && (
              <p
                class="text-xs font-mono px-3 py-2 rounded-lg mt-2 select-all cursor-pointer"
                style={`background-color: ${colors.secondary}; color: ${colors.text}; font-family: '${fonts.body}', sans-serif`}
              >
                {item.url}
              </p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}
