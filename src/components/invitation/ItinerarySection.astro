---
interface ItineraryItem {
  time: string;
  activity: string;
  description?: string;
}

interface Props {
  items: ItineraryItem[];
  colors: { primary: string; secondary: string; background: string; text: string };
  fonts: { heading: string; body: string };
  altBackground?: boolean;
}

const { items = [], colors, fonts, altBackground = false } = Astro.props;
const bgColor = altBackground ? colors.secondary : colors.background;
---

<section class="py-14 px-6 text-center" style={`background-color: ${bgColor}`}>
  <h2
    class="text-3xl mb-8"
    style={`font-family: '${fonts.heading}', cursive; color: ${colors.primary}`}
  >
    Itinerario
  </h2>

  <div class="max-w-xs mx-auto space-y-0">
    {items.map((item, i) => (
      <div class="flex gap-4 text-left pb-6 relative">
        {/* Timeline line */}
        {i < items.length - 1 && (
          <div class="absolute left-[19px] top-8 bottom-0 w-px" style={`background-color: ${colors.primary}; opacity: 0.3`} />
        )}
        {/* Timeline dot */}
        <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center mt-0.5" style={`background-color: ${colors.primary}; color: ${colors.background}`}>
          <span class="text-xs font-bold">{item.time}</span>
        </div>
        <div class="pt-2">
          <p class="font-semibold text-sm" style={`color: ${colors.text}`}>{item.activity}</p>
          {item.description && (
            <p class="text-xs mt-0.5" style={`color: ${colors.text}; opacity: 0.6`}>{item.description}</p>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
