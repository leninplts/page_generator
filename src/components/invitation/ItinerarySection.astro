---
interface ItineraryItem {
  time: string;
  activity: string;
  description?: string;
}

interface Props {
  items: ItineraryItem[];
  colors: { primary: string; secondary: string; accent: string; background: string; text: string };
  fonts: { heading: string; body: string };
  altBackground?: boolean;
  variant?: string;
}

const { items = [], colors, fonts, altBackground = false, variant = 'classic' } = Astro.props;
const bgColor = altBackground ? colors.secondary : colors.background;
---

<section class="py-20 px-6 text-center" style={`background-color: ${bgColor}`}>
  <div class="max-w-sm mx-auto">
    <h2
      class="text-4xl mb-12"
      style={`font-family: '${fonts.heading}', cursive; color: ${colors.primary}`}
    >
      Itinerario
    </h2>

    <div class="relative">
      {/* Vertical timeline line */}
      {items.length > 1 && (
        <div
          class="absolute left-6 top-3 bottom-3 w-px"
          style={`background-color: ${colors.accent}; opacity: 0.25`}
        />
      )}

      <div class="space-y-8">
        {items.map((item) => (
          <div class="flex gap-5 text-left relative">
            {/* Timeline dot */}
            <div
              class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-[10px] font-medium tracking-wider z-10"
              style={`background-color: ${colors.secondary}; color: ${colors.primary}; border: 1px solid ${colors.accent}; opacity: 0.8; font-family: '${fonts.body}', sans-serif`}
            >
              {item.time}
            </div>
            <div class="pt-3">
              <p
                class="text-sm font-semibold"
                style={`color: ${colors.text}; font-family: '${fonts.body}', sans-serif`}
              >
                {item.activity}
              </p>
              {item.description && (
                <p
                  class="text-xs mt-0.5"
                  style={`color: ${colors.text}; opacity: 0.5; font-family: '${fonts.body}', sans-serif`}
                >
                  {item.description}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
