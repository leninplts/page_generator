---
interface Props {
  title: string;
  placeName?: string;
  address?: string;
  time?: string;
  latitude?: number;
  longitude?: number;
  imageUrl?: string;
  colors: { primary: string; secondary: string; background: string; text: string };
  fonts: { heading: string; body: string };
  altBackground?: boolean;
}

const { title, placeName, address, time, latitude, longitude, imageUrl, colors, fonts, altBackground = false } = Astro.props;
const bgColor = altBackground ? colors.secondary : colors.background;
const mapsUrl = latitude && longitude
  ? `https://www.google.com/maps?q=${latitude},${longitude}`
  : address
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`
    : null;
---

<section class="py-14 px-6 text-center" style={`background-color: ${bgColor}`}>
  <h2
    class="text-3xl mb-6"
    style={`font-family: '${fonts.heading}', cursive; color: ${colors.primary}`}
  >
    {title}
  </h2>

  {placeName && (
    <p class="font-semibold text-sm tracking-widest uppercase mb-2" style={`color: ${colors.text}`}>
      {placeName}
    </p>
  )}

  {address && (
    <p class="text-sm mb-1" style={`color: ${colors.text}; opacity: 0.7`}>
      {address}
    </p>
  )}

  {time && (
    <p class="text-lg font-semibold mt-4 mb-4" style={`color: ${colors.primary}`}>
      {time} h
    </p>
  )}

  {imageUrl && (
    <div class="mt-6 -mx-6 overflow-hidden">
      <img src={imageUrl} alt={placeName || title} class="w-full h-56 object-cover" loading="lazy" />
    </div>
  )}

  {mapsUrl && (
    <a
      href={mapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 mt-6 px-6 py-2.5 rounded-full text-sm font-medium transition-opacity hover:opacity-80"
      style={`background-color: ${colors.primary}; color: ${colors.background}`}
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
      </svg>
      Ver en Maps
    </a>
  )}
</section>
