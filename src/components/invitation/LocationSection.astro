---
interface Props {
  title: string;
  placeName?: string;
  address?: string;
  time?: string;
  latitude?: number;
  longitude?: number;
  notes?: string;
  imageUrl?: string;
  colors: { primary: string; secondary: string; accent: string; background: string; text: string };
  fonts: { heading: string; body: string };
  altBackground?: boolean;
  variant?: string;
}

const { title, placeName, address, time, latitude, longitude, notes, imageUrl, colors, fonts, altBackground = false, variant = 'classic' } = Astro.props;
const bgColor = altBackground ? colors.secondary : colors.background;
const mapsUrl = latitude && longitude
  ? `https://www.google.com/maps?q=${latitude},${longitude}`
  : address
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`
    : null;
---

<section class="py-12 px-6 text-center" style={`background-color: ${bgColor}`}>
  <div class="max-w-md mx-auto">
    {/* Section title */}
    <h2
      class="text-4xl mb-8"
      style={`font-family: '${fonts.heading}', cursive; color: ${colors.primary}`}
    >
      {title}
    </h2>

    {/* Place name */}
    {placeName && (
      <p
        class="font-semibold text-xs tracking-[0.3em] uppercase mb-2"
        style={`color: ${colors.text}; font-family: '${fonts.body}', sans-serif`}
      >
        {placeName}
      </p>
    )}

    {/* Address */}
    {address && (
      <p
        class="text-sm mb-4"
        style={`color: ${colors.text}; opacity: 0.6; font-family: '${fonts.body}', sans-serif`}
      >
        {address}
      </p>
    )}

    {/* Time - prominent */}
    {time && (
      <p
        class="text-2xl font-light my-6"
        style={`color: ${colors.primary}; font-family: '${fonts.body}', sans-serif`}
      >
        {time} h
      </p>
    )}

    {/* Notes */}
    {notes && (
      <p
        class="text-xs italic mb-6"
        style={`color: ${colors.text}; opacity: 0.5; font-family: '${fonts.body}', sans-serif`}
      >
        {notes}
      </p>
    )}

    {/* Photo */}
    {imageUrl && (
      <div class="my-8 -mx-2 overflow-hidden rounded-lg">
        <img src={imageUrl} alt={placeName || title} class="w-full h-56 object-cover" loading="lazy" />
      </div>
    )}

    {/* Maps button */}
    {mapsUrl && (
      <div class="mt-8">
        {/* Map icon */}
        <div class="flex justify-center mb-3">
          <svg
            width="40" height="40" viewBox="0 0 24 24" fill="none"
            stroke={colors.primary} stroke-width="1" opacity="0.5"
            class="transition-opacity hover:opacity-80"
          >
            <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <a
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block text-xs tracking-[0.15em] uppercase underline underline-offset-4 decoration-1 transition-opacity hover:opacity-70"
          style={`color: ${colors.text}; opacity: 0.6; font-family: '${fonts.body}', sans-serif; text-decoration-color: ${colors.accent}`}
        >
          Pulsa para ver en Maps
        </a>
      </div>
    )}
  </div>
</section>
