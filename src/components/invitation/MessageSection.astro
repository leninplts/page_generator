---
interface Props {
  title?: string;
  content?: string;
  colors: { primary: string; secondary: string; accent: string; background: string; text: string };
  fonts: { heading: string; body: string };
  altBackground?: boolean;
  variant?: string;
}

const { title, content, colors, fonts, altBackground = false, variant = 'classic' } = Astro.props;
const bgColor = altBackground ? colors.secondary : colors.background;
---

<section class="py-24 px-6 text-center" style={`background-color: ${bgColor}`}>
  <div class="max-w-sm mx-auto">
    {variant === 'classic' && (
      <div class="mb-6 flex justify-center opacity-25">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke={colors.primary} stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </div>
    )}

    {title && (
      <h2
        class="text-4xl mb-8"
        style={`font-family: '${fonts.heading}', cursive; color: ${colors.primary}`}
      >
        {title}
      </h2>
    )}

    {content && (
      <p
        class="text-base leading-loose italic"
        style={`font-family: '${fonts.body}', sans-serif; color: ${colors.text}; opacity: 0.7`}
      >
        {content}
      </p>
    )}

    {variant === 'classic' && (
      <div class="mt-8 mx-auto w-12 h-px" style={`background-color: ${colors.accent}; opacity: 0.3`} />
    )}
  </div>
</section>
