---
interface Props {
  fromColor: string;
  toColor: string;
  variant?: string;
}

const { fromColor, toColor, variant = 'classic' } = Astro.props;

// Torn paper effect: fromColor (section above) tears apart revealing toColor (section below)
// The SVGs draw fromColor from top down with ragged bottom edge
// Background of container = toColor (revealed below the tear)
// Ragged edge points DOWNWARD = paper torn from above hangs down

// Layer 1 — shadow (slightly offset down for depth)
const tp1 = "M0,0 L1200,0 L1200,32 C1185,38 1165,28 1145,36 C1125,44 1108,30 1088,38 C1068,46 1050,32 1032,40 C1012,48 998,34 978,42 C958,50 942,36 922,44 C902,38 888,48 868,40 C848,32 832,44 812,36 C792,46 778,32 758,40 C738,48 722,34 702,42 C682,50 668,36 648,44 C628,38 612,48 592,40 C572,32 558,44 538,36 C518,46 502,32 482,40 C462,48 448,34 428,42 C408,50 392,36 372,44 C352,38 338,48 318,40 C298,32 282,44 262,36 C242,46 228,32 208,40 C188,48 172,34 152,42 C132,50 118,36 98,44 C78,38 62,48 42,40 C22,32 8,42 0,38 Z";

// Layer 2 — fiber edge (semi-transparent)
const tp2 = "M0,0 L1200,0 L1200,28 C1182,36 1162,24 1142,32 C1122,40 1102,28 1085,36 C1065,44 1048,30 1028,38 C1008,46 992,32 972,40 C952,48 938,34 918,42 C898,36 882,46 862,38 C842,28 828,42 808,34 C788,44 772,30 752,38 C732,46 718,32 698,40 C678,48 662,34 642,42 C622,36 608,46 588,38 C568,28 552,42 532,34 C512,44 498,30 478,38 C458,46 442,32 422,40 C402,48 388,34 368,42 C348,36 332,46 312,38 C292,28 278,42 258,34 C238,44 222,30 202,38 C182,46 168,32 148,40 C128,48 112,34 92,42 C72,36 58,46 38,38 C18,28 6,40 0,34 Z";

// Layer 3 — solid paper edge (front)
const tp3 = "M0,0 L1200,0 L1200,25 C1180,33 1160,22 1140,30 C1120,38 1100,26 1082,34 C1062,42 1045,28 1025,36 C1005,44 990,30 970,38 C950,46 935,32 915,40 C895,34 880,44 860,36 C840,26 825,40 805,32 C785,42 770,28 750,36 C730,44 715,30 695,38 C675,46 660,32 640,40 C620,34 605,44 585,36 C565,26 550,40 530,32 C510,42 495,28 475,36 C455,44 440,30 420,38 C400,46 385,32 365,40 C345,34 330,44 310,36 C290,26 275,40 255,32 C235,42 220,28 200,36 C180,44 165,30 145,38 C125,46 110,32 90,40 C70,34 55,44 35,36 C15,26 5,38 0,32 Z";
---

{variant === 'classic' && (
  <div class="relative -mt-1 overflow-hidden" style={`height: 50px; background-color: ${toColor}`}>
    {/* Layer 1: Shadow */}
    <svg
      class="absolute top-[4px] left-0 w-full"
      viewBox="0 0 1200 55"
      preserveAspectRatio="none"
      style="height: 50px; opacity: 0.07"
    >
      <path d={tp1} fill="#000" />
    </svg>
    {/* Layer 2: Semi-transparent fiber edge */}
    <svg
      class="absolute top-[2px] left-0 w-full"
      viewBox="0 0 1200 55"
      preserveAspectRatio="none"
      style="height: 50px; opacity: 0.3"
    >
      <path d={tp2} fill={fromColor} />
    </svg>
    {/* Layer 3: Solid paper edge */}
    <svg
      class="absolute top-0 left-0 w-full"
      viewBox="0 0 1200 55"
      preserveAspectRatio="none"
      style="height: 50px"
    >
      <path d={tp3} fill={fromColor} />
    </svg>
  </div>
)}

{variant === 'modern' && (
  <div class="flex justify-center py-4" style={`background-color: ${toColor}`}>
    <div class="w-16 h-px" style={`background-color: ${fromColor}; opacity: 0.2`} />
  </div>
)}

{variant === 'elegant' && (
  <div class="flex justify-center items-center py-3 gap-3" style={`background-color: ${toColor}`}>
    <div class="w-12 h-px" style={`background-color: ${fromColor}; opacity: 0.15`} />
    <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
      <rect x="2" y="2" width="4" height="4" transform="rotate(45 4 4)" stroke={fromColor} stroke-width="0.5" opacity="0.2" />
    </svg>
    <div class="w-12 h-px" style={`background-color: ${fromColor}; opacity: 0.15`} />
  </div>
)}
