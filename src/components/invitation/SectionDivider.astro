---
interface Props {
  fromColor: string;
  toColor: string;
  variant?: string;
}

const { fromColor, toColor, variant = 'classic' } = Astro.props;

// SVG paths: drawn from BOTTOM up, with ragged edge pointing UP
// This creates the effect of the bottom section's paper tearing upward
// fromColor = background (section ending above)
// toColor = SVG fill (section starting below, tears upward)
const tornPath1 = "M0,55 L1200,55 L1200,20 C1180,28 1160,14 1140,24 C1120,34 1105,18 1085,26 C1065,14 1045,30 1030,20 C1010,10 995,28 975,18 C960,8 940,26 920,16 C905,6 885,24 865,14 C845,20 830,8 810,18 C790,28 775,10 755,20 C735,8 720,26 700,14 C685,4 665,22 645,12 C625,18 610,6 590,16 C570,26 555,8 535,18 C515,28 500,10 480,20 C460,8 445,26 425,14 C405,4 390,22 370,12 C350,18 335,6 315,16 C295,26 280,8 260,18 C240,8 225,24 205,14 C185,4 170,22 150,12 C130,18 115,6 95,16 C75,26 60,8 40,18 C20,8 10,22 0,14 Z";

const tornPath2 = "M0,55 L1200,55 L1200,22 C1175,30 1155,16 1135,26 C1115,12 1095,30 1080,20 C1060,10 1040,28 1025,18 C1005,8 985,26 970,16 C950,6 935,24 915,14 C895,20 880,8 860,18 C840,28 825,12 805,20 C785,10 770,26 750,16 C730,6 715,22 695,12 C675,18 660,6 640,16 C620,26 605,10 585,18 C565,8 550,24 530,14 C510,20 495,8 475,16 C455,26 440,10 420,18 C400,8 385,24 365,14 C345,20 330,8 310,16 C290,26 275,10 255,18 C235,8 220,24 200,14 C180,20 165,8 145,16 C125,26 110,10 90,18 C70,8 55,24 35,14 C15,20 5,12 0,16 Z";

const tornPath3 = "M0,55 L1200,55 L1200,24 C1178,32 1158,18 1138,28 C1118,16 1098,32 1078,22 C1058,12 1038,28 1018,18 C998,8 978,26 963,16 C943,6 928,24 908,14 C888,20 873,8 853,18 C833,28 818,12 798,20 C778,10 763,26 743,16 C723,6 708,22 688,12 C668,18 653,6 633,16 C613,26 598,10 578,18 C558,8 543,24 523,14 C503,20 488,8 468,16 C448,26 433,10 413,18 C393,8 378,24 358,14 C338,20 323,8 303,16 C283,26 268,10 248,18 C228,8 213,24 193,14 C173,20 158,8 138,16 C118,26 103,10 83,18 C63,8 48,24 28,14 C8,20 3,12 0,16 Z";
---

{variant === 'classic' && (
  <div class="relative -mt-1 overflow-hidden" style={`height: 50px; background-color: ${fromColor}`}>
    {/* Layer 1: Shadow (deepest, slightly offset up) */}
    <svg
      class="absolute left-0 w-full"
      viewBox="0 0 1200 55"
      preserveAspectRatio="none"
      style={`bottom: 3px; height: 50px; opacity: 0.06`}
    >
      <path d={tornPath1} fill="#000" />
    </svg>
    {/* Layer 2: Mid-tone (semi-transparent = paper fiber effect) */}
    <svg
      class="absolute left-0 w-full"
      viewBox="0 0 1200 55"
      preserveAspectRatio="none"
      style={`bottom: 1px; height: 50px; opacity: 0.3`}
    >
      <path d={tornPath2} fill={toColor} />
    </svg>
    {/* Layer 3: Front — solid paper edge of incoming section */}
    <svg
      class="absolute bottom-0 left-0 w-full"
      viewBox="0 0 1200 55"
      preserveAspectRatio="none"
      style="height: 50px"
    >
      <path d={tornPath3} fill={toColor} />
    </svg>
  </div>
)}

{variant === 'modern' && (
  <div class="flex justify-center py-4" style={`background-color: ${toColor}`}>
    <div class="w-16 h-px" style={`background-color: ${fromColor}; opacity: 0.2`} />
  </div>
)}

{variant === 'elegant' && (
  <div class="flex justify-center items-center py-3 gap-3" style={`background-color: ${toColor}`}>
    <div class="w-12 h-px" style={`background-color: ${fromColor}; opacity: 0.15`} />
    <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
      <rect x="2" y="2" width="4" height="4" transform="rotate(45 4 4)" stroke={fromColor} stroke-width="0.5" opacity="0.2" />
    </svg>
    <div class="w-12 h-px" style={`background-color: ${fromColor}; opacity: 0.15`} />
  </div>
)}
