---
interface Props {
  fromColor: string;
  toColor: string;
  variant?: string;
}

const { fromColor, toColor, variant = 'classic' } = Astro.props;
---

{variant === 'classic' && (
  <div class="relative h-8 -mt-1 -mb-1" style={`background-color: ${toColor}`}>
    <div
      class="absolute top-0 left-0 right-0 h-full"
      style={`background-color: ${fromColor}; clip-path: polygon(0 0, 100% 0, 100% 30%, 98% 55%, 95% 35%, 92% 50%, 88% 30%, 85% 45%, 80% 25%, 75% 45%, 70% 30%, 65% 50%, 60% 25%, 55% 40%, 50% 20%, 45% 45%, 40% 30%, 35% 50%, 30% 25%, 25% 40%, 20% 20%, 15% 45%, 10% 30%, 5% 50%, 2% 35%, 0 50%)`}
    />
  </div>
)}

{variant === 'modern' && (
  <div class="flex justify-center py-6" style={`background-color: ${toColor}`}>
    <div class="w-16 h-px" style={`background-color: ${fromColor}; opacity: 0.2`} />
  </div>
)}

{variant === 'elegant' && (
  <div class="flex justify-center items-center py-4 gap-3" style={`background-color: ${toColor}`}>
    <div class="w-12 h-px" style={`background-color: ${fromColor}; opacity: 0.15`} />
    <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
      <rect x="2" y="2" width="4" height="4" transform="rotate(45 4 4)" stroke={fromColor} stroke-width="0.5" opacity="0.2" />
    </svg>
    <div class="w-12 h-px" style={`background-color: ${fromColor}; opacity: 0.15`} />
  </div>
)}
