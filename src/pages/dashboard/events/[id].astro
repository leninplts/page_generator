---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { SectionEditor } from '../../../components/editor/SectionEditor';
import { CustomizationPanel } from '../../../components/editor/CustomizationPanel';
import { SharePanel } from '../../../components/editor/SharePanel';
import { RsvpPanel } from '../../../components/editor/RsvpPanel';
import { db } from '../../../lib/db';
import { events, eventSections } from '../../../lib/db/schema';
import { eq, and, asc } from 'drizzle-orm';

export const prerender = false;

const user = Astro.locals.user;
const { id } = Astro.params;

if (!user) {
  return Astro.redirect('/auth/login');
}

const [event] = await db
  .select()
  .from(events)
  .where(and(eq(events.id, id!), eq(events.userId, user.id)));

if (!event) {
  return Astro.redirect('/dashboard');
}

const sections = await db
  .select()
  .from(eventSections)
  .where(eq(eventSections.eventId, event.id))
  .orderBy(asc(eventSections.order));

const eventTypeLabels: Record<string, string> = {
  birthday: 'Cumpleanos', xv: 'XV Anos', baptism: 'Bautizo',
  wedding: 'Boda', graduation: 'Graduacion',
};

const serializedSections = sections.map(s => ({
  id: s.id,
  sectionType: s.sectionType,
  order: s.order,
  isActive: s.isActive,
  config: s.config,
  content: s.content,
}));

// Parse customConfig with defaults
const rawConfig = (event.customConfig || {}) as Record<string, any>;
const customConfig = {
  colors: {
    primary: rawConfig.colors?.primary || '#6366f1',
    secondary: rawConfig.colors?.secondary || '#e0e7ff',
    accent: rawConfig.colors?.accent || '#818cf8',
    background: rawConfig.colors?.background || '#ffffff',
    text: rawConfig.colors?.text || '#1e293b',
  },
  fonts: {
    heading: rawConfig.fonts?.heading || 'Playfair Display',
    body: rawConfig.fonts?.body || 'Lato',
  },
};
---

<DashboardLayout title={event.title}>
  <div class="mb-6 flex items-center justify-between">
    <a href="/dashboard" class="inline-flex items-center text-sm text-slate-500 hover:text-slate-700 transition-colors">
      <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
      Volver a mis eventos
    </a>
    <a
      href={`/e/${event.slug}?preview=true`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      Vista previa
    </a>
  </div>

  {/* Event Info Header */}
  <div class="mb-6 rounded-2xl border border-slate-200 bg-white p-6">
    <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">
      {eventTypeLabels[event.eventType] || event.eventType}
    </span>
    <h2 class="mt-1 text-2xl font-bold text-slate-900">{event.title}</h2>
    {event.eventDate && (
      <p class="mt-1 text-slate-600">
        {new Date(event.eventDate + 'T00:00:00').toLocaleDateString('es-ES', {
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
        })}
        {event.eventTime && ` a las ${event.eventTime} hrs`}
      </p>
    )}
  </div>

  {/* Share & Publish Panel */}
  <div class="mb-6">
    <SharePanel
      client:load
      eventId={event.id}
      slug={event.slug}
      status={event.status as "draft" | "published" | "archived"}
      title={event.title}
    />
  </div>

  {/* RSVP Panel */}
  <div class="mb-6">
    <RsvpPanel
      client:load
      eventId={event.id}
    />
  </div>

  {/* Customization Panel */}
  <div class="mb-6">
    <CustomizationPanel
      client:load
      eventId={event.id}
      initialConfig={customConfig}
    />
  </div>

  {/* Section Editor */}
  <SectionEditor
    client:load
    eventId={event.id}
    initialSections={serializedSections}
  />
</DashboardLayout>
