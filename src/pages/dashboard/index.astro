---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { EmptyState } from '../../components/dashboard/EmptyState';
import { EventCard } from '../../components/dashboard/EventCard';
import { db } from '../../lib/db';
import { events } from '../../lib/db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user;

let userEvents: Array<{
  id: string;
  title: string;
  eventType: string;
  status: 'draft' | 'published' | 'archived';
  eventDate: string | null;
  slug: string;
}> = [];

if (user) {
  try {
    const result = await db
      .select({
        id: events.id,
        title: events.title,
        eventType: events.eventType,
        status: events.status,
        eventDate: events.eventDate,
        slug: events.slug,
      })
      .from(events)
      .where(eq(events.userId, user.id))
      .orderBy(desc(events.createdAt));

    userEvents = result;
  } catch (error) {
    console.error('Error fetching events:', error);
  }
}
---

<DashboardLayout title="Mis Eventos">
  {/* Stats bar */}
  <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-sm font-medium text-slate-500">Eventos Activos</p>
      <p class="mt-1 text-2xl font-bold text-slate-900">{userEvents.filter(e => e.status === 'published').length}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-sm font-medium text-slate-500">Borradores</p>
      <p class="mt-1 text-2xl font-bold text-slate-900">{userEvents.filter(e => e.status === 'draft').length}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-sm font-medium text-slate-500">Total de Eventos</p>
      <p class="mt-1 text-2xl font-bold text-slate-900">{userEvents.length}</p>
    </div>
  </div>

  {/* Events grid or empty state */}
  {userEvents.length > 0 ? (
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {userEvents.map((event) => (
        <EventCard
          id={event.id}
          title={event.title}
          eventType={event.eventType}
          status={event.status}
          eventDate={event.eventDate}
          slug={event.slug}
        />
      ))}
    </div>
  ) : (
    <EmptyState
      title="No tienes eventos aun"
      description="Crea tu primera invitacion digital y compartela con tus invitados por WhatsApp."
      actionLabel="Crear mi primer evento"
      actionHref="/dashboard/events/new"
    />
  )}
</DashboardLayout>
