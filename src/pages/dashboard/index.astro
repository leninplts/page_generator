---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { EmptyState } from '../../components/dashboard/EmptyState';
import { EventCard } from '../../components/dashboard/EventCard';

const user = Astro.locals.user;

// TODO: Fetch events from database
// For now, show empty state
const events: Array<{
  title: string;
  eventType: string;
  status: 'draft' | 'published' | 'archived';
  eventDate: string | null;
  slug: string;
}> = [];
---

<DashboardLayout title="Mis Eventos">
  {/* Stats bar */}
  <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-sm font-medium text-slate-500">Eventos Activos</p>
      <p class="mt-1 text-2xl font-bold text-slate-900">{events.filter(e => e.status === 'published').length}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-sm font-medium text-slate-500">Borradores</p>
      <p class="mt-1 text-2xl font-bold text-slate-900">{events.filter(e => e.status === 'draft').length}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-sm font-medium text-slate-500">Total de Eventos</p>
      <p class="mt-1 text-2xl font-bold text-slate-900">{events.length}</p>
    </div>
  </div>

  {/* Events grid or empty state */}
  {events.length > 0 ? (
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {events.map((event) => (
        <EventCard
          title={event.title}
          eventType={event.eventType}
          status={event.status}
          eventDate={event.eventDate}
          slug={event.slug}
        />
      ))}
    </div>
  ) : (
    <EmptyState
      title="No tienes eventos aun"
      description="Crea tu primera invitacion digital y compartela con tus invitados por WhatsApp."
      actionLabel="Crear mi primer evento"
      actionHref="/dashboard/events/new"
    />
  )}
</DashboardLayout>
