---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { EmptyState } from '../../components/dashboard/EmptyState';
import { EventList } from '../../components/dashboard/EventList';
import { db } from '../../lib/db';
import { events } from '../../lib/db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user;

let userEvents: Array<{
  id: string;
  title: string;
  eventType: string;
  status: 'draft' | 'published' | 'archived';
  eventDate: string | null;
  slug: string;
  createdAt: Date;
}> = [];

if (user) {
  try {
    const result = await db
      .select({
        id: events.id,
        title: events.title,
        eventType: events.eventType,
        status: events.status,
        eventDate: events.eventDate,
        slug: events.slug,
        createdAt: events.createdAt,
      })
      .from(events)
      .where(eq(events.userId, user.id))
      .orderBy(desc(events.createdAt));

    userEvents = result;
  } catch (error) {
    console.error('Error fetching events:', error);
  }
}

const publishedCount = userEvents.filter(e => e.status === 'published').length;
const draftCount = userEvents.filter(e => e.status === 'draft').length;
const totalCount = userEvents.length;


---

<DashboardLayout title="Mis Eventos">
  {/* Stat Cards */}
  <div class="mb-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {/* Total Events - Gradient Card */}
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-orange-500 to-rose-500 p-5 text-white shadow-lg shadow-orange-500/25">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-orange-100">Total Eventos</p>
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-white/20">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </div>
      </div>
      <p class="mt-3 text-3xl font-bold">{totalCount}</p>
      <p class="mt-1 text-xs text-orange-100">Invitaciones creadas</p>
    </div>

    {/* Published */}
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-slate-500">Publicados</p>
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-50">
          <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
      </div>
      <p class="mt-3 text-3xl font-bold text-slate-900">{publishedCount}</p>
      <p class="mt-1 text-xs text-emerald-600 font-medium">Activos en linea</p>
    </div>

    {/* Drafts */}
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-slate-500">Borradores</p>
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-amber-50">
          <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
          </svg>
        </div>
      </div>
      <p class="mt-3 text-3xl font-bold text-slate-900">{draftCount}</p>
      <p class="mt-1 text-xs text-amber-600 font-medium">En progreso</p>
    </div>

    {/* Quick Action */}
    <a href="/dashboard/events/new" class="group flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 bg-white p-5 transition-all hover:border-orange-400 hover:bg-orange-50/50 hover:shadow-sm">
      <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-orange-100 text-orange-600 transition-transform group-hover:scale-110">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
      </div>
      <p class="mt-3 text-sm font-semibold text-slate-700 group-hover:text-orange-600">Crear Evento</p>
      <p class="text-xs text-slate-400">Nueva invitacion</p>
    </a>
  </div>

  {userEvents.length > 0 ? (
    <EventList
      client:load
      events={userEvents.map(e => ({
        id: e.id,
        title: e.title,
        eventType: e.eventType,
        status: e.status,
        eventDate: e.eventDate,
        slug: e.slug,
      }))}
    />
  ) : (
    <EmptyState
      title="No tienes eventos aun"
      description="Crea tu primera invitacion digital y compartela con tus invitados por WhatsApp."
      actionLabel="Crear mi primer evento"
      actionHref="/dashboard/events/new"
    />
  )}
</DashboardLayout>
