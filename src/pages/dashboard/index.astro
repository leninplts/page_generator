---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { EmptyState } from '../../components/dashboard/EmptyState';
import { EventCard } from '../../components/dashboard/EventCard';
import { db } from '../../lib/db';
import { events } from '../../lib/db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user;

let userEvents: Array<{
  id: string;
  title: string;
  eventType: string;
  status: 'draft' | 'published' | 'archived';
  eventDate: string | null;
  slug: string;
  createdAt: Date;
}> = [];

if (user) {
  try {
    const result = await db
      .select({
        id: events.id,
        title: events.title,
        eventType: events.eventType,
        status: events.status,
        eventDate: events.eventDate,
        slug: events.slug,
        createdAt: events.createdAt,
      })
      .from(events)
      .where(eq(events.userId, user.id))
      .orderBy(desc(events.createdAt));

    userEvents = result;
  } catch (error) {
    console.error('Error fetching events:', error);
  }
}

const publishedCount = userEvents.filter(e => e.status === 'published').length;
const draftCount = userEvents.filter(e => e.status === 'draft').length;
const totalCount = userEvents.length;

const eventTypeIcons: Record<string, string> = {
  birthday: '🎂', xv: '👑', baptism: '✝️', wedding: '💍', graduation: '🎓',
};
const eventTypeLabels: Record<string, string> = {
  birthday: 'Cumpleanos', xv: 'XV Anos', baptism: 'Bautizo', wedding: 'Boda', graduation: 'Graduacion',
};
const statusConfig: Record<string, { dot: string; text: string; label: string }> = {
  draft: { dot: 'bg-amber-400', text: 'text-amber-700', label: 'Borrador' },
  published: { dot: 'bg-emerald-400', text: 'text-emerald-700', label: 'Publicado' },
  archived: { dot: 'bg-slate-400', text: 'text-slate-600', label: 'Archivado' },
};
---

<DashboardLayout title="Mis Eventos">
  {/* Stat Cards */}
  <div class="mb-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {/* Total Events - Gradient Card */}
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-orange-500 to-rose-500 p-5 text-white shadow-lg shadow-orange-500/25">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-orange-100">Total Eventos</p>
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-white/20">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </div>
      </div>
      <p class="mt-3 text-3xl font-bold">{totalCount}</p>
      <p class="mt-1 text-xs text-orange-100">Invitaciones creadas</p>
    </div>

    {/* Published */}
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-slate-500">Publicados</p>
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-50">
          <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
      </div>
      <p class="mt-3 text-3xl font-bold text-slate-900">{publishedCount}</p>
      <p class="mt-1 text-xs text-emerald-600 font-medium">Activos en linea</p>
    </div>

    {/* Drafts */}
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-slate-500">Borradores</p>
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-amber-50">
          <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
          </svg>
        </div>
      </div>
      <p class="mt-3 text-3xl font-bold text-slate-900">{draftCount}</p>
      <p class="mt-1 text-xs text-amber-600 font-medium">En progreso</p>
    </div>

    {/* Quick Action */}
    <a href="/dashboard/events/new" class="group flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 bg-white p-5 transition-all hover:border-orange-400 hover:bg-orange-50/50 hover:shadow-sm">
      <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-orange-100 text-orange-600 transition-transform group-hover:scale-110">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
      </div>
      <p class="mt-3 text-sm font-semibold text-slate-700 group-hover:text-orange-600">Crear Evento</p>
      <p class="text-xs text-slate-400">Nueva invitacion</p>
    </a>
  </div>

  {userEvents.length > 0 ? (
    <>
      {/* Recent Events Table */}
      <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="flex items-center justify-between border-b border-slate-100 px-6 py-4">
          <h2 class="text-lg font-semibold text-slate-900">Eventos Recientes</h2>
          <div class="flex items-center gap-2">
            <div class="relative hidden sm:block">
              <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
              </svg>
              <input type="text" placeholder="Buscar..." class="h-9 w-48 rounded-lg border border-slate-200 pl-9 pr-3 text-sm placeholder:text-slate-400 focus:border-orange-300 focus:outline-none focus:ring-1 focus:ring-orange-500/20" />
            </div>
          </div>
        </div>

        {/* Table */}
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-slate-100">
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-400">Evento</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-400">Tipo</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-400">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-400">Fecha</th>
                <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-400">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              {userEvents.slice(0, 10).map((event) => {
                const st = statusConfig[event.status] || statusConfig.draft;
                return (
                  <tr class="group transition-colors hover:bg-slate-50/50">
                    <td class="px-6 py-4">
                      <a href={`/dashboard/events/${event.id}`} class="flex items-center gap-3">
                        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-slate-100 text-lg">
                          {eventTypeIcons[event.eventType] || '📅'}
                        </span>
                        <span class="text-sm font-medium text-slate-900 group-hover:text-orange-600 transition-colors">
                          {event.title}
                        </span>
                      </a>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-sm text-slate-500">{eventTypeLabels[event.eventType] || event.eventType}</span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center gap-1.5">
                        <span class={`h-2 w-2 rounded-full ${st.dot}`}></span>
                        <span class={`text-sm font-medium ${st.text}`}>{st.label}</span>
                      </span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-sm text-slate-500">
                        {event.eventDate
                          ? new Date(event.eventDate).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })
                          : 'Sin fecha'}
                      </span>
                    </td>
                    <td class="px-6 py-4 text-right">
                      <a
                        href={`/dashboard/events/${event.id}`}
                        class="inline-flex items-center gap-1 rounded-lg px-3 py-1.5 text-xs font-medium text-slate-500 hover:bg-slate-100 hover:text-slate-700 transition-colors"
                      >
                        Editar
                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                        </svg>
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      {/* Event Cards Grid (below table for card view) */}
      <div class="mt-8">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Vista de tarjetas</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {userEvents.map((event) => (
            <EventCard
              client:load
              id={event.id}
              title={event.title}
              eventType={event.eventType}
              status={event.status}
              eventDate={event.eventDate}
              slug={event.slug}
            />
          ))}
        </div>
      </div>
    </>
  ) : (
    <EmptyState
      title="No tienes eventos aun"
      description="Crea tu primera invitacion digital y compartela con tus invitados por WhatsApp."
      actionLabel="Crear mi primer evento"
      actionHref="/dashboard/events/new"
    />
  )}
</DashboardLayout>
