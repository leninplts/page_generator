---
import '../../styles/global.css';
export const prerender = false;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invitacion no disponible</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lato:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body style="font-family: 'Lato', sans-serif; background-color: #faf9f7; margin: 0;">
    <div style="max-width: 448px; margin: 0 auto; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; text-align: center;">
      <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #e0e7ff, #c7d2fe); display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
        <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="#6366f1" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
      </div>
      <h1 style="font-family: 'Playfair Display', serif; font-size: 1.75rem; color: #1e293b; margin-bottom: 0.75rem;">
        Invitacion no disponible
      </h1>
      <p style="color: #64748b; font-size: 0.95rem; line-height: 1.6; max-width: 320px;">
        Esta invitacion aun no ha sido publicada o fue archivada por el organizador.
      </p>
      <p style="color: #94a3b8; font-size: 0.8rem; margin-top: 2rem;">
        Si crees que esto es un error, contacta a quien te envio el enlace.
      </p>
    </div>
  </body>
</html>
